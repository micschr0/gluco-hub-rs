{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],

  "timezone": "Europe/Berlin",
  "schedule": ["after 8am and before 6pm on Monday"],

  "cargo": {
    "rangeStrategy": "update-lockfile"
  },

  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"],
    "automerge": false
  },

  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["after 8am and before 6pm on Sunday"]
  },

  "packageRules": [
    {
      "description": "Group the tokio ecosystem into a single PR",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["tokio*"],
      "groupName": "tokio ecosystem",
      "automerge": true
    },
    {
      "description": "Group the serde ecosystem into a single PR",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["serde*"],
      "groupName": "serde ecosystem",
      "automerge": true
    },
    {
      "description": "Group the axum / tower ecosystem into a single PR",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["axum*", "tower*"],
      "groupName": "axum + tower ecosystem",
      "automerge": true
    },
    {
      "description": "Group the tracing ecosystem into a single PR",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["tracing*"],
      "groupName": "tracing ecosystem",
      "automerge": true
    },
    {
      "description": "Automerge non-major Cargo updates after 7d soak (CI is the gate)",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "minor"],
      "minimumReleaseAge": "7 days",
      "automerge": true
    },
    {
      "description": "Automerge GitHub Actions minor/patch/digest bumps",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Major Cargo updates require manual review",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
