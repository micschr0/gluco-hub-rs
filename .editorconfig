root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.rs]
indent_size = 4

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
indent_size = 2
# Two trailing spaces are a hard line break in Markdown — don't strip them.
trim_trailing_whitespace = false
